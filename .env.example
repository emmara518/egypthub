# ===== مصر هب - EgyptHub Environment Variables =====

# Database
POSTGRES_USER=egypthub
POSTGRES_PASSWORD=egypthub_secret_2024
POSTGRES_DB=egypthub_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# API Gateway
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
LISTINGS_SERVICE_PORT=4002
BOOKINGS_SERVICE_PORT=4003
AMBASSADOR_SERVICE_PORT=4004

# OTP (SMS - Use your provider)
SMS_PROVIDER=mock
SMS_API_KEY=

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Next.js Apps
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin
ADMIN_EMAIL=admin@egypthub.com
ADMIN_PHONE=01000000000
ADMIN_PASSWORD=Admin@123456
